---
export interface Props {
  title: string;
  category: string;
  thumbnail: string;
  embedUrl?: string;
}

const { title, category, thumbnail, embedUrl } = Astro.props;
const isInteractive = !!embedUrl;
// Determine if this is an external link (Instagram, etc.) vs embeddable (YouTube/Vimeo)
const isExternalLink = embedUrl && (embedUrl.includes('instagram.com') || embedUrl.includes('tiktok.com'));
const isEmbeddable = isInteractive && !isExternalLink;
---

<article
  class:list={['work-card', { 'work-card--interactive': isInteractive }]}
  data-category={category}
>
  {isEmbeddable ? (
    <button
      class="work-card__trigger"
      type="button"
      data-embed-url={embedUrl}
      data-title={title}
      aria-label={`Play ${title}`}
    >
      <img
        src={thumbnail}
        alt={title}
        loading="lazy"
        class="work-card__img"
      />
      <div class="work-card__overlay">
        <p class="work-card__category label">{category}</p>
        <h3 class="work-card__title">{title}</h3>
      </div>
    </button>
  ) : isExternalLink ? (
    <a
      href={embedUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="work-card__link"
      aria-label={`View ${title} on Instagram`}
    >
      <img
        src={thumbnail}
        alt={title}
        loading="lazy"
        class="work-card__img"
      />
      <div class="work-card__overlay">
        <p class="work-card__category label">{category}</p>
        <h3 class="work-card__title">{title}</h3>
      </div>
    </a>
  ) : (
    <div class="work-card__static">
      <img
        src={thumbnail}
        alt={title}
        loading="lazy"
        class="work-card__img"
      />
      <div class="work-card__overlay">
        <p class="work-card__category label">{category}</p>
        <h3 class="work-card__title">{title}</h3>
      </div>
    </div>
  )}
</article>

<style>
  .work-card {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 4px;
    background: var(--color-bg-card);
  }

  .work-card__trigger,
  .work-card__static,
  .work-card__link {
    position: relative;
    width: 100%;
    height: 100%;
    display: block;
    padding: 0;
    border: none;
    background: none;
    cursor: default;
    text-decoration: none;
  }

  .work-card__trigger,
  .work-card__link {
    cursor: pointer;
  }

  .work-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .work-card:hover .work-card__img,
  .work-card:focus-within .work-card__img {
    transform: scale(1.05);
  }

  .work-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 300ms var(--ease-out);
  }

  .work-card:hover .work-card__overlay,
  .work-card:focus-within .work-card__overlay {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card__overlay {
      opacity: 1;
    }
    .work-card__img {
      transition: none;
    }
  }

  .work-card__category {
    font-size: 0.625rem;
    margin-bottom: 0.25rem;
  }

  .work-card__title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-text);
  }
</style>
