---
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID || 'xrgvqkzl';
---

<form
  id="contact-form"
  class="contact-form"
  action={`https://formspree.io/f/${formspreeId}`}
  method="POST"
  novalidate
>
  <!-- Honeypot -->
  <div class="contact-form__honeypot" aria-hidden="true">
    <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
  </div>

  <div class="contact-form__field">
    <label for="contact-name" class="contact-form__label">Name *</label>
    <input
      type="text"
      id="contact-name"
      name="name"
      required
      maxlength="100"
      class="contact-form__input"
      aria-describedby="contact-name-error"
    />
    <p id="contact-name-error" class="contact-form__error" aria-live="polite"></p>
  </div>

  <div class="contact-form__field">
    <label for="contact-email" class="contact-form__label">Email *</label>
    <input
      type="email"
      id="contact-email"
      name="email"
      required
      maxlength="254"
      class="contact-form__input"
      aria-describedby="contact-email-error"
    />
    <p id="contact-email-error" class="contact-form__error" aria-live="polite"></p>
  </div>

  <div class="contact-form__field">
    <label for="contact-subject" class="contact-form__label">Subject</label>
    <input
      type="text"
      id="contact-subject"
      name="subject"
      maxlength="200"
      class="contact-form__input"
    />
  </div>

  <div class="contact-form__field">
    <label for="contact-message" class="contact-form__label">Message *</label>
    <textarea
      id="contact-message"
      name="message"
      required
      maxlength="5000"
      rows="6"
      class="contact-form__textarea"
      aria-describedby="contact-message-error"
    ></textarea>
    <p id="contact-message-error" class="contact-form__error" aria-live="polite"></p>
  </div>

  <button type="submit" class="btn btn--accent contact-form__submit">
    Send Message
  </button>

  <!-- Success/Error messages -->
  <div id="contact-success" class="contact-form__success" hidden>
    <p>Thanks for reaching out! I'll get back to you soon.</p>
  </div>
  <div id="contact-error" class="contact-form__server-error" hidden>
    <p>Something went wrong. Please try again later or reach out through social media.</p>
  </div>
</form>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-form__honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-form__label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: var(--tracking-cinematic);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .contact-form__input,
  .contact-form__textarea {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 0.875rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-text);
    transition: border-color var(--dur-fast) var(--ease-out);
    min-height: 44px;
  }

  .contact-form__input:focus,
  .contact-form__textarea:focus {
    border-color: var(--color-accent);
    outline: none;
  }

  .contact-form__textarea {
    resize: vertical;
    min-height: 140px;
  }

  .contact-form__error {
    font-size: 0.8125rem;
    color: #e53e3e;
    min-height: 1.2em;
  }

  .contact-form__submit {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  .contact-form__success {
    padding: 1rem;
    background: rgba(201, 168, 76, 0.1);
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    color: var(--color-accent);
  }

  .contact-form__server-error {
    padding: 1rem;
    background: rgba(229, 62, 62, 0.1);
    border: 1px solid #e53e3e;
    border-radius: 4px;
    color: #e53e3e;
  }

  .contact-form__server-error a {
    color: inherit;
    text-decoration: underline;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;

    const successEl = document.getElementById('contact-success');
    const errorEl = document.getElementById('contact-error');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Reset messages
      successEl?.setAttribute('hidden', '');
      errorEl?.setAttribute('hidden', '');

      // Clear previous errors
      form.querySelectorAll('.contact-form__error').forEach((el) => {
        el.textContent = '';
      });

      // Validate required fields
      let isValid = true;

      const nameInput = form.querySelector<HTMLInputElement>('#contact-name');
      const emailInput = form.querySelector<HTMLInputElement>('#contact-email');
      const messageInput = form.querySelector<HTMLTextAreaElement>('#contact-message');

      if (nameInput && !nameInput.value.trim()) {
        const err = document.getElementById('contact-name-error');
        if (err) err.textContent = 'Please enter your name.';
        isValid = false;
      }

      if (emailInput) {
        if (!emailInput.value.trim()) {
          const err = document.getElementById('contact-email-error');
          if (err) err.textContent = 'Please enter your email address.';
          isValid = false;
        } else if (!emailInput.validity.valid) {
          const err = document.getElementById('contact-email-error');
          if (err) err.textContent = 'Please enter a valid email address.';
          isValid = false;
        }
      }

      if (messageInput && !messageInput.value.trim()) {
        const err = document.getElementById('contact-message-error');
        if (err) err.textContent = 'Please enter a message.';
        isValid = false;
      }

      if (!isValid) return;

      // Submit via fetch
      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });

        if (response.ok) {
          form.reset();
          form.style.display = 'none';
          successEl?.removeAttribute('hidden');
        } else {
          errorEl?.removeAttribute('hidden');
        }
      } catch {
        errorEl?.removeAttribute('hidden');
      }
    });
  });
</script>
