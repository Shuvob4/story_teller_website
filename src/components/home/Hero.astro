---
import { getEntry } from 'astro:content';

const homeData = await getEntry('pages', 'home');
const heroVideoUrl = homeData?.data?.heroVideoUrl || '';
const heroPosterImage = homeData?.data?.heroPosterImage || '/uploads/hero-poster.jpg';
---

<section class="hero grain" aria-label="Hero" id="hero-section">
  <!-- Video background -->
  <video
    class="hero__video"
    autoplay
    muted
    loop
    playsinline
    poster={heroPosterImage}
    aria-hidden="true"
  >
    {heroVideoUrl && <source src={heroVideoUrl} type="video/mp4" />}
  </video>

  <!-- Gradient overlay -->
  <div class="hero__overlay" aria-hidden="true"></div>

  <!-- Film grain (from .grain class ::before) is handled by the class -->

  <!-- Content -->
  <div class="hero__content">
    <p class="hero__eyebrow label" data-hero-animate>Tauseef Alamgir Turjjo</p>
    <h1 class="hero__headline" data-hero-animate>Life Through a<br />Cinematic Lens</h1>
    <div class="hero__cta" data-hero-animate>
      <a href="/work" class="btn btn--accent">View Work</a>
      <a href="/contact" class="btn btn--ghost">Get in Touch</a>
    </div>
  </div>
</section>



<style>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0.75));
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: var(--z-content);
    text-align: center;
    padding: 2rem;
    max-width: 900px;
  }

  .hero__eyebrow {
    margin-bottom: 1.5rem;
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 5rem);
    line-height: 1.1;
    color: var(--color-text);
    margin-bottom: 2.5rem;
  }

  .hero__cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
