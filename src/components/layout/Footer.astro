---
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Work', href: '/work' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Contact', href: '/contact' },
];

const socials = [
  { label: 'YouTube', href: 'https://www.youtube.com/@turjjo2004', icon: 'youtube' },
  { label: 'TikTok', href: 'https://www.tiktok.com/@tauseefalamgirtur', icon: 'tiktok' },
  { label: 'Instagram', href: 'https://www.instagram.com/turjjo', icon: 'instagram' },
  { label: 'Facebook', href: 'https://www.facebook.com/turjjo20', icon: 'facebook' },
];
---

<footer class="footer" role="contentinfo">
  <div class="footer__inner">
    <!-- Logo -->
    <a href="/" class="footer__logo" aria-label="Turjjo Portfolio — Home">
      <img src="/logo/logo.png" alt="Turjjo — Life Through a Cinematic Lens" width="256" height="256" />
    </a>

    <!-- Navigation links -->
    <nav aria-label="Footer navigation" class="footer__nav">
      <ul class="footer__links">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="footer__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Social Links -->
    <div class="footer__socials">
      <a href="https://www.youtube.com/@turjjo2004" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="footer__social">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
      <a href="https://www.tiktok.com/@tauseefalamgirtur" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="footer__social">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.88 2.89 2.89 0 0 1-2.88-2.88 2.89 2.89 0 0 1 2.88-2.88c.28 0 .56.04.82.1v-3.5a6.37 6.37 0 0 0-.82-.05A6.34 6.34 0 0 0 3.15 15.7 6.34 6.34 0 0 0 9.49 22a6.34 6.34 0 0 0 6.34-6.34V9.4a8.16 8.16 0 0 0 4.77 1.53V7.48a4.85 4.85 0 0 1-1.01-.79z"/></svg>
      </a>
      <a href="https://www.instagram.com/turjjo" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="footer__social">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
      </a>
      <a href="https://www.facebook.com/turjjo20" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="footer__social">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
    </div>

    <!-- Copyright -->
    <p class="footer__copyright">
      &copy; {currentYear} Tauseef Alamgir Turjjo. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 3rem 2rem;
    margin-top: 4.5rem;
  }

  .footer__inner {
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    min-width: 44px;
    min-height: 44px;
  }

  .footer__logo img {
    width: 256px;
    height: 256px;
    object-fit: contain;
  }

  .footer__nav {
    margin: 0;
  }

  .footer__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__link {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: var(--tracking-cinematic);
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color var(--dur-fast) var(--ease-out);
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  .footer__link:hover {
    color: var(--color-accent);
  }

  .footer__socials {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .footer__social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-text-muted);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .footer__social:hover {
    color: var(--color-accent);
  }

  .footer__copyright {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }
</style>
